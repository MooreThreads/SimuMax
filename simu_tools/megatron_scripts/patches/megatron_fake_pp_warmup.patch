+def _get_warmup_pipeline_parallel_size(real_pp_size: int) -> int:
+    """Optionally override warmup-depth modeling without changing real PP comm topology."""
+    fake_pp_size = os.environ.get("MEGATRON_FAKE_PP_SIZE_FOR_WARMUP")
+    if fake_pp_size is None:
+        return real_pp_size
+    fake_pp_size = int(fake_pp_size)
+    if fake_pp_size < real_pp_size:
+        raise ValueError(
+            "MEGATRON_FAKE_PP_SIZE_FOR_WARMUP must be >= real pipeline parallel size, "
+            f"but got fake={fake_pp_size}, real={real_pp_size}"
+        )
+    return fake_pp_size
+
